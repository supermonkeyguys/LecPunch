{
  "name": "@lecpunch/shared",
  "version": "0.1.0",
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "guard:no-js-src": "node ./scripts/assert-no-js-in-src.cjs",
    "prebuild": "pnpm run guard:no-js-src",
    "build": "tsc -b --force",
    "lint": "eslint \"src/**/*.ts\"",
    "pretypecheck": "pnpm run guard:no-js-src",
    "typecheck": "tsc -b",
    "test": "pnpm run guard:no-js-src"
  }
}
