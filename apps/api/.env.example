NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://localhost:27017/lecpunch
# Minimum 16 characters. Replace in shared or production environments.
AUTH_SECRET=change-me-please-1234
DEFAULT_TEAM_NAME=FocusTeam
# Keep true only for local development or demo environments.
ALLOW_OPEN_REGISTRATION=true
# Enables balanced accounting (server-credited slices + pause/resume semantics).
ATTENDANCE_BALANCED_ACCOUNTING_ENABLED=true
# When false, configure at least one allowlist below.
ALLOW_ANY_NETWORK=true
# Comma-separated exact client IP allowlist.
ALLOWED_PUBLIC_IPS=127.0.0.1
# Comma-separated CIDR allowlist for office LAN / VPN ranges.
ALLOWED_CIDRS=192.168.0.0/16
# Trust X-Forwarded-For only when requests always pass through your own proxy chain.
TRUST_PROXY=false
# Number of trusted proxies counted from the right side of X-Forwarded-For.
TRUSTED_PROXY_HOPS=1
