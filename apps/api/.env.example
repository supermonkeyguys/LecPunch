NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://localhost:27017/lecpunch
AUTH_SECRET=lecPunchCookieCC
DEFAULT_TEAM_NAME=FocusTeam
ALLOW_OPEN_REGISTRATION=true
# Set to false outside local development to enforce the allowlists below.
ALLOW_ANY_NETWORK=true
# Comma-separated exact client IP allowlist.
ALLOWED_PUBLIC_IPS=127.0.0.1
# Comma-separated CIDR allowlist for office LAN / VPN ranges.
ALLOWED_CIDRS=192.168.0.0/16
# Only trust X-Forwarded-For when requests always pass through your own proxy chain.
TRUST_PROXY=false
# Number of trusted proxies on the right side of X-Forwarded-For.
TRUSTED_PROXY_HOPS=1
