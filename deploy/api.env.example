# Copy to deploy/api.env on the server before running docker compose.
NODE_ENV=production
PORT=4000
MONGODB_URI=mongodb://lecpunch:change-this-mongo-password@mongo:27017/lecpunch?authSource=admin

# Replace with a long random secret before exposing the app to anyone else.
AUTH_SECRET=replace-with-a-long-random-secret
DEFAULT_TEAM_NAME=FocusTeam

# Keep registration open for the first small-scale test only if you need self-service sign-up.
ALLOW_OPEN_REGISTRATION=true

# Recommended first boot: keep this true, log in as admin, then configure the
# stricter policy from /admin/network-policy after you confirm the actual public IP.
ALLOW_ANY_NETWORK=true
ALLOWED_PUBLIC_IPS=
ALLOWED_CIDRS=

# The API sits behind nginx in Docker, so trust a single proxy hop.
TRUST_PROXY=true
TRUSTED_PROXY_HOPS=1
